# ── Executor (Agent 推理引擎，可切换 OpenAI / Kimi / DeepSeek 等) ──
# 方式 A: 使用 OpenAI (默认)
EXECUTOR_MODEL=gpt-4o
EXECUTOR_API_KEY=sk-ant-...

# 方式 B: 使用 Kimi (月之暗面)
# EXECUTOR_MODEL=moonshot-v1-8k
# EXECUTOR_API_KEY=sk-...
# EXECUTOR_BASE_URL=https://api.moonshot.cn/v1

# 方式 C: 使用 DeepSeek
# EXECUTOR_MODEL=deepseek-chat
# EXECUTOR_API_KEY=sk-...
# EXECUTOR_BASE_URL=https://api.deepseek.com/v1

# ── 改写 Rewriter / 反思 Reflector / 记忆 Memory（目前用的是Qwen） ──
DASHSCOPE_API_KEY=sk-...

# ── Serper (网络搜索，可选) ──
SERPER_API_KEY=...

# ── LlamaParse (PDF 解析，数据 ingest 时需要) ──
LLAMA_CLOUD_API_KEY=...

# ── 可选覆盖 ──
# MAX_RECENT_MESSAGES=5
# MAX_ITERATIONS=3
# MEMORY_DIR=.sessions
# MILVUS_URI=./milvus.db
# DATA_ROOT=data
# NIO_CAR_MODELS=EC6,EC7,ES6,ES8,ET5,ET5T,ET7,ET9
