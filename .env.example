# Copy to .env and fill in your values

# Claude (main agent)
ANTHROPIC_API_KEY=sk-ant-...

# Qwen via DashScope — verify model ID at https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-...
QWEN_MODEL=qwen3.5-instruct

# Serper (web search) — also set in websearch/src/config/config.yaml
SERPER_API_KEY=...

# Optional overrides
# CLAUDE_MODEL=claude-sonnet-4-6
# MILVUS_URI=./milvus.db
# DATA_ROOT=data
# NIO_CAR_MODELS=EC6,ET5,ES8,ET7,EL6
# SUMMARY_INTERVAL=6
# MAX_RECENT_MESSAGES=5
# MAX_ITERATIONS=3
